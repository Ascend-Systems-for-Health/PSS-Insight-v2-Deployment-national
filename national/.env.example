# ---------------------------------------------------------------------------
# PSS Insight v2.0 — National deployment environment (TEMPLATE)
#
# Copy this file to `.env` and fill in values for your deployment:
#     cp .env.example .env
#
# This is a derivative work distributed under GPL-3.0 (see ../LICENSE, ../NOTICE).
#
# SECURITY NOTE
# The `.env` committed in this repo holds PUBLIC DHIS2 DEMO defaults
# (username `admin` / password `district`) for the AS-IS demo instance only.
# For any real or country deployment you MUST NOT reuse those defaults — set
# strong, unique credentials below AND update the matching database passwords
# in docker-compose.yaml (POSTGRES_PASSWORD for the `db` and
# `pss_ws_national_db` services, which default to `dhis` / `postgres`).
# ---------------------------------------------------------------------------

# --- DHIS2 core ---
DHIS2_CORE_IMAGE=dhis2/core:2.38.0
DHIS2_CORE_PORT=80
DHIS2_CORE_CONTEXT_PATH=
DHIS2_CORE_CONFIG=
DHIS2_HOME=/opt/dhis2

# --- Data synchronization credentials (DHIS2 admin/service accounts) ---
# CHANGE THESE for real deployments. Do NOT reuse the demo admin/district.
SOURCE_USERNAME=<dhis2-username>
SOURCE_PASSWORD=changeme
SOURCE_URL=https://<your-national-host>/api/events
TARGET_USERNAME=<dhis2-username>
TARGET_PASSWORD=changeme
TARGET_URL=https://<your-international-host>/api/events
SOURCE_DATA_ELEMENTS_URL=https://<your-national-host>/api/dataElements

# --- App release artifacts (version-pinned upstream zips) ---
DHIS2_DATA_ENTRY_RELEASE_URL=https://github.com/IntelliSOFT-Consulting/PSS-Insight-v2-Dataentry-Dhis2App/archive/refs/tags/V1.0.0.zip
DHIS2_CONFIG_RELEASE_URL=https://github.com/IntelliSOFT-Consulting/PSS-Insight-v2-National-Dhis2App/archive/refs/tags/v1.0.0.zip
DHIS2_DATA_IMPORT_RELEASE_URL=https://github.com/IntelliSOFT-Consulting/PSS-Insight-v2-Data-Import/archive/refs/tags/v1.0.0.zip
DHIS2_INDICATOR_SYNC_RELEASE_URL=https://github.com/IntelliSOFT-Consulting/PSS-Insight-v2-Indicator-Sync-Dhis2App/archive/refs/tags/v1.0.0.zip

# --- Spring profile for pss_ws_national (localdev | local) ---
SPRING_PROFILES_ACTIVE=localdev
